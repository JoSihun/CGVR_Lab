{{>header}}
{{>banner}}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <!-- 좌측 열 -->
        <div class="col-xl-2">
            <!-- 연구생 정보 -->
            <div class="row justify-content-end">
                <div class="card shadow mb-4 text-dark bg-light">
                    <!-- Card Header -->
                    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                        <h5 class="m-0 font-weight-bold">연구생 정보</h5>
                    </div>

                    <!-- Card Body -->
                    <!-- 나중에 변수 처리 해야함 -->
                    <div class="card-body" style="text-align: center">
                        <div><a class="card-text text-dark" href="#">최영환</a></div>
                        <div><a class="card-text text-dark" href="#">조시훈</a></div>
                        <div><a class="card-text text-dark" href="#">염동빈</a></div>
                    </div>
                </div>
            </div>

            <!-- 글쓰기 -->
            <div class="row justify-content-end">
                <button type="button" class="btn btn-dark btn-lg mb-4">글쓰기</button>
            </div>

            <!-- 연구 게시판 -->
            <div class="row justify-content-end">
                <div class="card shadow mb-4 text-dark bg-light">
                    <!-- Card Header -->
                    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                        <h5 class="m-0 font-weight-bold">연구 게시판</h5>
                    </div>

                    <!-- Card Body -->
                    <div class="card-body" style="text-align: center">
                        <div><a class="card-text text-dark" href="#">프로젝트 1</a></div>
                        <div><a class="card-text text-dark" href="#">프로젝트 2</a></div>
                        <div><a class="card-text text-dark" href="#">프로젝트 3</a></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 우측 열 -->
        <div class="col-xl-6">
                <div class="card shadow mb-4 text-dark bg-light">
                    <!-- Card Header -->
                    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                        <h5 class="m-0 font-weight-bold">연구 공지사항</h5>
                    </div>

                    <!-- Card Body -->
                    <div class="card-body">
                        <div><a class="card-text text-dark" href="#">글 제목 1</a></div>
                        <div><a class="card-text text-dark" href="#">글 제목 2</a></div>
                        <div><a class="card-text text-dark" href="#">글 제목 3</a></div>
                        <div><a class="card-text text-dark" href="#">글 제목 4</a></div>
                        <div><a class="card-text text-dark" href="#">글 제목 5</a></div>
                        <div><a class="card-text text-dark" href="#">글 제목 6</a></div>
                        <div><a class="card-text text-dark" href="#">글 제목 7</a></div>
                        <div><a class="card-text text-dark" href="#">글 제목 8</a></div>
                        <div><a class="card-text text-dark" href="#">글 제목 9</a></div>
                        <div><a class="card-text text-dark" href="#">글 제목 10</a></div>
                    </div>
                </div>
        </div>
    </div>

</div>

{{>footer}}